# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Email Configuration (SMTP settings)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_SERVICE=gmail

# Application Name
APP_NAME=Roomie

# Application Configuration Urls
BASE_URL=https://your-domain.com
# BASE_URL=http://localhost:8080

# Server Port
SERVER_PORT=8080

# --- Accounting month auto-close (History / ledger archive) ---
# Default ON when unset: previous calendar month is snapshot+closed for every flat automatically.
# Set to false only if you intentionally manage month-close manually.
# AUTO_CLOSE_PREVIOUS_ACCOUNTING_MONTH=true
#
# Daily run uses the server's local timezone (set TZ on the host if needed, e.g. Asia/Kolkata).
# Default 00:05 = five minutes after midnight local — avoids edge cases exactly at 00:00.
# ACCOUNTING_MONTH_CLOSE_RUN_HOUR=0
# ACCOUNTING_MONTH_CLOSE_RUN_MINUTE=5

# Web Push Notification VAPID Keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourapp.com


# Session Configuration (used in auth.ts)
# REPL_ID is used as a unique identifier for session management and security
# This should be a unique UUID/GUID that identifies your application instance
# You can generate one using online UUID generators or command: node -e "console.log(require('crypto').randomUUID())"
# Example format: 12345678-1234-1234-1234-123456789abc
REPL_ID=your_unique_repl_id

# Optional: MongoDB TTL on Activity.timestamp (seconds, min 3600). Omit to rely on per-user cap of 30 rows only.
# ACTIVITY_LOG_RETENTION_SECONDS=7776000
